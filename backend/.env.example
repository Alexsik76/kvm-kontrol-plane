# ==============================================================================
# IP-KVM Control Plane — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to version control.
# ==============================================================================

# --- Application ---
APP_TITLE="IP-KVM Control Plane"
APP_VERSION="0.1.0"
DEBUG=false
# Comma-separated list of allowed CORS origins (browser clients)
CORS_ORIGINS="http://localhost:3000,https://kvm.yourdomain.com"

# --- Database ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://kvmuser:changeme@db:5432/kvmdb"

# --- JWT ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY="replace_me_with_a_random_32_byte_hex_string"
JWT_ALGORITHM="HS256"
# Token lifetimes in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080    # 7 days

# --- First Superuser (seeded by db/init_db.py) ---
FIRST_SUPERUSER="admin"
FIRST_SUPERUSER_EMAIL="admin@kvm.local"
FIRST_SUPERUSER_PASSWORD="changeme"

# --- Node Health Poller ---
# Interval (seconds) between health-check cycles
NODE_POLL_INTERVAL_SECONDS=15
# Timeout (seconds) for a single MediaMTX API call
NODE_HTTP_TIMEOUT_SECONDS=5

# --- Cloudflare Tunnels ---
# Public HTTPS URL of this Control-Plane API
KVM_API_TUNNEL_URL="https://kvm-api.lab.vn.ua"
# Default Cloudflare Tunnel HTTPS URL for RPi nodes
NODE_DEFAULT_TUNNEL_URL="https://pi4.lab.vn.ua"

# --- PostgreSQL (used by docker-compose for the db service) ---
POSTGRES_USER="kvmuser"
POSTGRES_PASSWORD="changeme"
POSTGRES_DB="kvmdb"
