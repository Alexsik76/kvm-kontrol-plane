# ==============================================================================
# .dockerignore — exclude files that should not be sent to the Docker daemon
# ==============================================================================

# Python artefacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Test / lint artefacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Editor / IDE metadata
.idea/
.vscode/
*.swp
*.swo

# Sensitive files — NEVER include in image
.env
*.pem
*.key
*.crt

# Git
.git/
.gitignore

# Documentation that doesn't belong in the image
README.md
docs/
